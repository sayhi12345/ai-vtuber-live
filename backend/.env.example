APP_NAME=ai-vtuber-live
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DEFAULT_LLM_PROVIDER=openai
DEFAULT_TTS_PROVIDER=qwen

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_CHAT_MODEL=gpt-4.1-nano
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=nova

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_CHAT_MODEL=gemini-3.1-flash-lite-preview
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE=Leda

QWEN_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice
QWEN_TTS_DEVICE=auto
QWEN_TTS_DTYPE=auto
QWEN_TTS_ATTN_IMPLEMENTATION=sdpa
QWEN_TTS_LANGUAGE=Chinese
QWEN_TTS_SPEAKER=Vivian
QWEN_TTS_INSTRUCTIONS=用自然、活潑的語氣說話，像一位個性鮮明的 AI VTuber，語速適中，情感真實。

SQLITE_PATH=./data/ai_vtuber.db
HISTORY_LIMIT=12
SAFETY_BLOCKLIST=self-harm,kill yourself,炸彈,恐怖攻擊
